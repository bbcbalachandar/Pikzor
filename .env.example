# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Public base URL — used in generated image URLs returned by the API
BASE_URL=https://pikzor.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/app.db

# ── Redis ─────────────────────────────────────────────────────────────────────
# App degrades gracefully if Redis is unavailable (renders without cache)
REDIS_URL=redis://127.0.0.1:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<generate-random-64-char-string>

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory where rendered PNG files are persisted on disk
STORAGE_PATH=./storage

# ── Logging ───────────────────────────────────────────────────────────────────
LOGS_DIR=./logs

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated extra origins allowed to call /api/* endpoints
# BASE_URL is always included automatically
CORS_ALLOWED_ORIGINS=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_yyy

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
