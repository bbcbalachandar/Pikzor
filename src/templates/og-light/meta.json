{
  "id": "og-light",
  "name": "OG Light",
  "description": "Clean white background with brand color left accent bar. Supports an optional description line.",
  "width": 1200,
  "height": 630,
  "variables": [
    { "key": "title",       "label": "Post Title",      "required": true  },
    { "key": "description", "label": "Short Description","required": false, "default": "" },
    { "key": "author",      "label": "Author Name",     "required": false, "default": "" },
    { "key": "date",        "label": "Publish Date",    "required": false, "default": "" },
    { "key": "tag",         "label": "Tag / Category",  "required": false, "default": "Blog Post" },
    { "key": "brand_color", "label": "Brand Color",     "required": false, "default": "#6366f1" },
    { "key": "logo_url",    "label": "Logo URL",        "required": false, "default": "" },
    { "key": "domain",      "label": "Domain",          "required": false, "default": "" }
  ]
